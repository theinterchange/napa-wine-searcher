# Database (Turso/libsql)
DATABASE_URL=file:./data/winery.db
DATABASE_AUTH_TOKEN=

# Auth.js (NextAuth v5)
AUTH_SECRET=your-secret-here

# Google Maps (for map view)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAP_ID=

# OpenAI (for AI-powered features, optional)
OPENAI_API_KEY=

# Google Places API (for winery data enrichment, optional)
GOOGLE_PLACES_API_KEY=

# Resend (for transactional emails: password reset, etc.)
RESEND_API_KEY=

# Wine Ratings API (optional)
WINE_SEARCHER_API_KEY=

# Analytics (Plausible — privacy-friendly, no cookie consent needed)
# Only loads in production when set
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
