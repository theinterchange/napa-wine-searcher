{
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "napasonomaguide.com"
        }
      ],
      "destination": "https://www.napasonomaguide.com/:path",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/gsc-import",
      "schedule": "0 6 * * *"
    }
  ]
}
